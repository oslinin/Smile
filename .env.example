# Deployer private key (no 0x prefix)
PRIVATE_KEY=

# RPC endpoints
RPC_SEPOLIA=https://sepolia.infura.io/v3/YOUR_KEY
RPC_MAINNET=https://mainnet.infura.io/v3/YOUR_KEY

# Chainlink CRE forwarder address (set after CRE workflow is registered)
CRE_FORWARDER=

# WETH address (defaults to mainnet if unset)
WETH_ADDRESS=0xC02aaA39b223FE8D0A0e5C4F27eAD9083C756Cc2

# WalletConnect — get a free project ID at cloud.walletconnect.com
NEXT_PUBLIC_WC_PROJECT_ID=

# Uniswap Trading API — get a key at developer.uniswap.org
# Used to fetch live ETH/USDC spot price (optional — falls back to $3420)
NEXT_PUBLIC_UNISWAP_API_KEY=

# Filled in by `forge script script/Deploy.s.sol --broadcast`
NEXT_PUBLIC_PRICING_ENGINE=
NEXT_PUBLIC_AQUA_VAULT=
NEXT_PUBLIC_SETTLEMENT=

# ── AI Copilot (chat panel in the dApp) ──────────────────────────────────────
# Put these in frontend/.env.local — local.sh preserves them across restarts.
# Provider: anthropic | openai | google. Only the matching key is required.
# Keys stay server-side (no NEXT_PUBLIC_ prefix — never sent to the browser).
COPILOT_PROVIDER=anthropic
# Optional model override (defaults: claude-opus-4-8 / gpt-5-mini / gemini-2.5-pro)
COPILOT_MODEL=
ANTHROPIC_API_KEY=
OPENAI_API_KEY=
GOOGLE_GENERATIVE_AI_API_KEY=
# RPC used by copilot on-chain reads when the UI is on Sepolia (optional)
COPILOT_RPC_SEPOLIA=
# Show the copilot widget (unset on the static GitHub Pages build, which has no API server)
NEXT_PUBLIC_COPILOT=1
